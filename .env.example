# Shakthi Journal — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ─── Strava OAuth ─────────────────────────────────────────────────────────────
# Register your app at https://www.strava.com/settings/api
# WARNING: In a browser-only app, VITE_ vars are bundled into the JS.
# This is acceptable for personal/dev use. For production, use a backend proxy.
VITE_STRAVA_CLIENT_ID=
VITE_STRAVA_CLIENT_SECRET=
VITE_STRAVA_REDIRECT_URI=http://localhost:5173/oauth/strava/callback

# ─── App ──────────────────────────────────────────────────────────────────────
VITE_APP_VERSION=0.2.0
